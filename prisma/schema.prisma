generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ENUM untuk status tugas
enum TaskStatus {
  Todo
  In_Progress
  Done
}

// 1. Fitur: Melakukan Autentikasi
model User {
  id             String             @id @default(uuid())
  username       String
  email          String             @unique
  password       String
  createdAt      DateTime           @default(now())

  tasks          Task[]
  focusSessions  FocusSession[]
  collaborations TaskCollaborator[]
}

// 2. Fitur: Melihat Daftar Prioritas Tugas (Tabel Master)
model Priority {
  id          Int      @id @default(autoincrement())
  name        String   // High, Medium, Low
  colorCode   String?  // Contoh: #FF0000

  tasks       Task[]
}

// 3. Fitur: Mengelola Data Tugas
model Task {
  id             String        @id @default(uuid())
  title          String
  description    String?

  status         TaskStatus    @default(Todo)

  dueDate        DateTime?

  // Custom Label
  customLabel    String?

  // Kode untuk kolaborasi
  taskCode       String        @unique @default(uuid())

  createdAt      DateTime      @default(now())

  userId         String
  user           User          @relation(fields: [userId], references: [id])

  priorityId     Int
  priority       Priority      @relation(fields: [priorityId], references: [id])

  focusSessions  FocusSession[]
  collaborators  TaskCollaborator[]
}

// 4. Fitur: Menggunakan Focus Mode
model FocusSession {
  id             String    @id @default(uuid())
  duration       Int
  startTime      DateTime
  endTime        DateTime
  createdAt      DateTime  @default(now())

  userId         String
  user           User      @relation(fields: [userId], references: [id])

  taskId         String?
  task           Task?     @relation(fields: [taskId], references: [id])
}

// 5. Fitur: Mengelola Kolaborasi Tugas
model TaskCollaborator {
  id             String    @id @default(uuid())
  joinedAt       DateTime  @default(now())

  taskId         String
  task           Task      @relation(fields: [taskId], references: [id])

  userId         String
  user           User      @relation(fields: [userId], references: [id])
}